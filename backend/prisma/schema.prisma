generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CharityTab {
  ORG
  CAMPAIGN
  MERCHANDISE
}

model Charity {
  id             String     @id @default(cuid())
  title          String
  description    String
  tab            CharityTab
  categoryCodes  String[]   @default([])  // 一個 item 可屬多個 sub-category
  logoUrl        String?
  amountRaised   Int        @default(0)
  amountGoal     Int?
  createdAt      DateTime   @default(now())

  // Polymorphic per-tab 欄位（option A — 全部 nullable 在 Charity，不獨立 model）
  bannerImageUrl  String?  // CAMPAIGN 上方 banner 圖
  orgName         String?  // CAMPAIGN + MERCHANDISE 所屬公益團體名稱
  tags            String[] @default([]) // CAMPAIGN 紅色 tag pill（= categoryCodes 對應 label）
  productImageUrl String?  // MERCHANDISE 商品方圖
  priceNtd        Int?     // MERCHANDISE 售價（NTD）

  @@index([tab, createdAt(sort: Desc)])
  @@index([categoryCodes], type: Gin)
}
